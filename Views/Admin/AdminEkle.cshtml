
@{
    ViewBag.Title = "AdminEkle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content pt-4">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-12 col-lg-15">
                <div class="card custom-exp-card">
                    <div class="card-body p-4">
                        <h3 class="custom-exp-title">Yeni Kullanıcı Ekle</h3>
                        <p class="custom-exp-text">Kullanıcı bilgilerini aşağıdaki alanlardan ekleyebilirsin.</p>

                        <form method="post">
                            <div class="form-group">
                                <label>Kullanıcı Adı</label>
                                <input type="text" name="KullaniciAdi" class="form-control custom-input" placeholder="Kullanıcı Adı" />
                            </div>

                            <div class="form-group">
                                <label>Şifre</label>
                                <input type="text" name="Sifre" class="form-control custom-input" placeholder="Şifre" />
                            </div>

                            <div class="d-flex justify-content-end mt-4">
                                <a href="/Admin/Index/" class="btn custom-cancel-btn mr-2">Vazgeç</a>
                                <button type="submit" class="btn custom-save-btn">Kaydet</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

