
@using MvcCv.Models.Entity
@model List<Tbl_Admin>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content pt-3">
    <div class="container-fluid">

        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title"><b>Admin İşlemleri</b></h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover text-nowrap mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>#</th>
                            <th>Kullanıcı Adı</th>
                            <th>Düzenle</th>
                            <th>Kaldır</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ID</td>
                                <td><strong>@item.KullaniciAdi</strong></td>

                                <td>
                                    <a href="/Admin/AdminGetir/@item.ID" class="btn btn-sm btn-outline-warning">
                                        Düzenle
                                    </a>
                                </td>
                                <td>
                                    <a href="/Admin/AdminSil/@item.ID" class="btn btn-sm btn-outline-danger">
                                        Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
        <a href="/Admin/AdminEkle/" class="btn btn-outline-primary btn-sm">+ Yeni Kullanıcı</a>
    </div>
</section>

