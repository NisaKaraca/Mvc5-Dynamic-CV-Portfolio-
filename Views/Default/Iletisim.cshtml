<div class="resume-section-content">
    <div class="contact-card">
        <h2 class="mb-4">İletişim</h2>
        <p class="contact-text">Benimle iletişime geçmek için aşağıdaki formu doldurabilirsiniz.</p>

        <form method="post" class="contact-form">
            <div class="form-group mb-3">
                <label>Ad Soyad</label>
                <input type="text" class="form-control modern-input" name="AdSoyad" placeholder="Adınızı ve soyadınızı girin" />
            </div>

            <div class="form-group mb-3">
                <label>Mail</label>
                <input type="email" class="form-control modern-input" name="Mail" placeholder="Mail adresinizi girin" />
            </div>

            <div class="form-group mb-3">
                <label>Konu</label>
                <input type="text" class="form-control modern-input" name="Konu" placeholder="Mesaj konusu" />
            </div>

            <div class="form-group mb-4">
                <label>Mesaj</label>
                <textarea class="form-control modern-input modern-textarea" name="Mesaj" rows="5" placeholder="Mesajınızı yazın"></textarea>
            </div>

            <button type="submit" class="btn modern-btn">Mesaj Gönder</button>
        </form>
    </div>
</div>