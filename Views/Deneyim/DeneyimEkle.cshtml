@{
    ViewBag.Title = "DeneyimEkle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content pt-4">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-12 col-lg-15">
                <div class="card custom-exp-card">
                    <div class="card-body p-4">
                        <h3 class="custom-exp-title">Yeni Deneyim Ekle</h3>
                        <p class="custom-exp-text">Deneyim bilgilerini aşağıdaki alanlardan ekleyebilirsin.</p>

                        <form method="post">
                            <div class="form-group">
                                <label>Başlık</label>
                                <input type="text" name="Baslik" class="form-control custom-input" placeholder="Örn: Yazılım Geliştirici" />
                            </div>

                            <div class="form-group">
                                <label>Alt Başlık</label>
                                <input type="text" name="AltBaslik" class="form-control custom-input" placeholder="Örn: Şirket / Kurum Adı" />
                            </div>

                            <div class="form-group">
                                <label>Açıklama</label>
                                <textarea name="Aciklama" class="form-control custom-input custom-textarea" rows="5" placeholder="Yaptığınız işleri detaylı yazın"></textarea>
                            </div>

                            <div class="form-group">
                                <label>Tarih</label>
                                <input type="text" name="Tarih" class="form-control custom-input" placeholder="Örn: 2024 - 2025" />
                            </div>

                            <div class="d-flex justify-content-end mt-4">
                                <a href="/Deneyim/Index/" class="btn custom-cancel-btn mr-2">Vazgeç</a>
                                <button type="submit" class="btn custom-save-btn">Kaydet</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>