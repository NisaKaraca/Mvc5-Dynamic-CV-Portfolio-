@using MvcCv.Models.Entity
@model List<Tbl_Deneyimlerim>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content pt-3">
    <div class="container-fluid">

        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title"><b>Deneyimlerim</b></h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover text-nowrap mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>#</th>
                            <th>Başlık</th>
                            <th>Alt Başlık</th>
                            <th>Tarih</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ID</td>
                                <td><strong>@item.Baslik</strong></td>
                                <td>@item.AltBaslik</td>
                                <td>
                                    <span class="badge badge-secondary">
                                        @item.Tarih
                                    </span>
                                </td>

                                <td class="text-center">
                                    <a href="/Deneyim/DeneyimGetir/@item.ID" class="btn btn-sm btn-outline-warning">
                                        Düzenle
                                    </a>

                                    <a href="/Deneyim/DeneyimSil/@item.ID" class="btn btn-sm btn-outline-danger">
                                        Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
        <a href="/Deneyim/DeneyimEkle/" class="btn btn-outline-primary btn-sm">+ Yeni Deneyim</a>
    </div>
</section>