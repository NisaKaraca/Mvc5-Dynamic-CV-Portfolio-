@model List<MvcCv.Models.Entity.Tbl_Hakkimda>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-10 offset-md-1">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title"><b>Hakkımda Bilgilerini Düzenleme Sayfası</b></h3>
                    </div>

                    <div class="card-body">
                        @foreach (var item in Model)
                        {
                            <form method="post" class="mb-4">
                                <input type="hidden" name="ID" value="@item.ID" />

                                <div class="form-group">
                                    <label><b>Ad</b></label>
                                    <textarea rows="1" class="form-control" name="Ad">@item.Ad</textarea>
                                </div>

                                <div class="form-group">
                                    <label><b>Soyad</b></label>
                                    <textarea rows="1" class="form-control" name="Soyad">@item.Soyad</textarea>
                                </div>

                                <div class="form-group">
                                    <label><b>Adres</b></label>
                                    <textarea rows="1" class="form-control" name="Adres">@item.Adres</textarea>
                                </div>

                                <div class="form-group">
                                    <label><b>Telefon</b></label>
                                    <textarea rows="1" class="form-control" name="Telefon">@item.Telefon</textarea>
                                </div>

                                <div class="form-group">
                                    <label><b>Açıklama</b></label>
                                    <textarea rows="5" class="form-control" name="Aciklama">@item.Aciklama</textarea>
                                </div>

                                <div class="form-group">
                                    <label><b>Mail</b></label>
                                    <textarea rows="1" class="form-control" name="Mail">@item.Mail</textarea>
                                </div>

                                <div class="form-group">
                                    <label><b>Resim</b></label>
                                    <textarea rows="1" class="form-control" name="Resim">@item.Resim</textarea>
                                </div>

                                <button type="submit" class="btn btn-outline-success btn-sm">
                                    Güncelle
                                </button>

                                <hr />
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>