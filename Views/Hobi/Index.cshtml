@using MvcCv.Models.Entity
@model List<Tbl_Hobilerim>

@{
    ViewBag.Title = "Hobilerim";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-10 offset-md-1">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title"><b>Hobi Düzenleme Sayfası</b></h3>
                    </div>

                    <div class="card-body">
                        @foreach (var item in Model)
                        {
                            <form method="post" class="mb-4">
                                <input type="hidden" name="ID" value="@item.ID" />

                                <div class="form-group">
                                    <label><b>Açıklama 1</b></label>
                                    <textarea rows="5" class="form-control" name="Aciklama1">@item.Aciklama1</textarea>
                                </div>

                                <div class="form-group">
                                    <label><b>Açıklama 2</b></label>
                                    <textarea rows="5" class="form-control" name="Aciklama2">@item.Aciklama2</textarea>
                                </div>

                                <button type="submit" class="btn btn-outline-success btn-sm">
                                    Güncelle
                                </button>

                                <hr />
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>