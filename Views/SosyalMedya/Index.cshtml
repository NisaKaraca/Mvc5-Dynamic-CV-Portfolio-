@using MvcCv.Models.Entity
@model List<Tbl_SosyalMedya>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!DOCTYPE html>
<html>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">

        <section class="content">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-12">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title"><b>Sosyal Medya Hesap Listem</b></h3>
                            </div>
                            <div class="card-body">
                                <table class="table table-bordered">
                                    <thead>
                                        <tr>
                                            <th style="width: 10px">#</th>
                                            <th>Sosyal Medya</th>
                                            <th>Durum</th>
                                            <th>Düzenle</th>
                                            <th>Sil</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.ID</td>
                                                <td>@item.Ad</td>
                                                @if(@item.Durum == true)
                                                {
                                                     <td><span class="badge badge-success">Aktif</span></td>
                                                
                                                }
                                                else
                                                {
                                                    <td><span class="badge badge-secondary">Pasif</span></td>
                                                }
                                                <td>
                                                    <a class="btn btn-outline-info btn-sm" href="/SosyalMedya/SayfaGetir/@item.ID">
                                                        <i class="fas fa-pencil-alt">
                                                        </i>
                                                        Düzenle
                                                    </a>
                                                </td>
                                                <td>
                                                    <a class="btn btn-outline-danger btn-sm" href="/SosyalMedya/Sil/@item.ID">
                                                        <i class="fas fa-trash">
                                                        </i>
                                                        Sil
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <br />
                                <button class="btn btn-outline-primary btn-sm" data-toggle="modal" data-target="#Modal1">+ Yeni Sosyal Medya</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <div class="modal fade" id="Modal1">
            <div class="modal-dialog modal-md">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">
                            <i class="fas fa-share-alt"></i> Sosyal Medya Ekle
                        </h5>
                        <button type="button" class="close text-white" data-dismiss="modal">
                            &times;
                        </button>
                    </div>
                    <form method="post" action="/SosyalMedya/Ekle">
                        <div class="modal-body">
                            <div class="form-group">
                                <label><b>Sosyal Medya İsmi</b></label>
                                <input type="text" name="Ad" class="form-control" placeholder="Örn: Instagram">
                            </div>

                            <div class="form-group">
                                <label><b>Link</b></label>
                                <input type="text" name="Link" class="form-control" placeholder="https://...">
                            </div>

                            <div class="form-group">
                                <label><b>İkon</b></label>
                                <input type="text" name="Ikon" class="form-control" placeholder="fab fa-instagram">
                                <small class="text-muted">Font Awesome ikon değeri giriniz</small>
                            </div>

                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">
                                Kapat
                            </button>
                            <button type="submit" class="btn btn-outline-primary">
                                <i class="fas fa-save"></i> Kaydet
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</body>
</html>



