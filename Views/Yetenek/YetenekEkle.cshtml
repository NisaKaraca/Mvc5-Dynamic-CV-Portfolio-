@model MvcCv.Models.Entity.Tbl_Yeteneklerim 
@{
    ViewBag.Title = "YetenekEkle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="content pt-4">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-12 col-lg-15">
                <div class="card custom-exp-card">
                    <div class="card-body p-4">
                        <h3 class="custom-exp-title">Deneyim Güncelle</h3>
                        <p class="custom-exp-text">Yeni yetenek bilgilerini aşağıdaki alanlardan ekleyebilirsiniz.</p>

                        <form method="post">
                            <div class="form-group">
                                <label>Yetenek Açıklaması</label>
                                @Html.TextBoxFor(x => x.Yetenek, new { @class = "form-control custom-input" })
                            </div>

                            <div class="form-group">
                                <label>Derece</label>
                                @Html.TextBoxFor(x => x.Oran, new { @class = "form-control custom-input" })
                            </div>

                            <div class="d-flex justify-content-end mt-4">
                                <a href="/Yetenek/Index/" class="btn custom-cancel-btn mr-2">Vazgeç</a>
                                <button type="submit" class="btn custom-save-btn">Ekle</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

